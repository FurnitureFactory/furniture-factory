# Copy to .env and fill in ( .env is gitignored — never commit it )
# cp .env.example .env

# Friend's site login — kept for your records / one-time browser signup.
# GitHub & Vercel CLI cannot log in with email+password; use tokens below.
FRIEND_EMAIL=
FRIEND_PASSWORD=

# GitHub: log in as friend → Settings → Developer settings → Personal access tokens
# Classic token with "repo" scope → paste here
GITHUB_TOKEN=

# Vercel: log in as friend (Continue with GitHub) → Account → Tokens → Create
VERCEL_TOKEN=

# Stripe: dashboard.stripe.com → Developers → API keys
# Use test keys first (sk_test_… / pk_test_…), then live keys for production
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=

# Optional overrides
GITHUB_REPO=furniture-factory
VERCEL_PROJECT=furniture-factory
